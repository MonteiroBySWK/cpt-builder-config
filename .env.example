# .env.example - Arquivo de exemplo para credenciais (COPIAR para .env e editar)
# IMPORTANTE: Nunca commit .env com valores reais!

# Credenciais SSH
CPT_CREDENTIALS_PASSWORD=adminssh
CPT_CREDENTIALS_ENABLE_PASSWORD=root

# Domínio (pode sobrescrever config.yml)
# CPT_GLOBAL_DOMAIN_NAME=uema.br

# SSH (pode sobrescrever config.yml)
# CPT_SSH_ENABLED=true
# CPT_SSH_VTY_RANGE=0 4
# CPT_SSH_TRANSPORT=ssh

# Interfaces (pode sobrescrever config.yml)
# CPT_INTERFACES_ROUTER_DEFAULT_PREFIX=GigabitEthernet
# CPT_INTERFACES_ROUTER_DEFAULT_SLOT=0

# VLANs
# CPT_VLANS_NATIVE_VLAN=99
